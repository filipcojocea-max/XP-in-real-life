ave', {\n      method: 'POST',\n      body: JSON.stringify({\n        entry_id,\n        edited_base64\n      })\n    }),\n    // ── Build Self-Confidence mini-app ──────────────────────────\n    // Today's daily challenge for each non-AI track + completion state.\n    confidenceDaily: () => req('/confidence/daily'),\n    confidenceComplete: (track, note) => req('/confidence/complete', {\n      method: 'POST',\n      body: JSON.stringify({\n        track,\n        note: note || ''\n      })\n    }),\n    confidenceDressAdvice: payload => req('/confidence/dress-advice', {\n      method: 'POST',\n      body: JSON.stringify(payload)\n    }),\n    confidenceDressHistory: (limit = 30) => req(`/confidence/dress-history?limit=${limit}`),\n    confidenceDressHistoryDelete: entry_id => req(`/confidence/dress-history/${entry_id}`, {\n      method: 'DELETE'\n    }),\n    confidenceWeather: (lat, lon) => req(`/confidence/weather?lat=${lat}&lon=${lon}`),\n    // ─── Focus Mode ──────────────────────────────────────────────────\n    focusSession: payload => req('/focus/session', {\n      method: 'POST',\n      body: JSON.stringify(payload)\n    }),\n    // ─── Spot the Object — Multiplayer/Lobby (Phase 2) ──────────────\n    spotMatchCreate: friend_ids => req('/spot/match/create', {\n      method: 'POST',\n      body: JSON.stringify({\n        friend_ids\n      })\n    }),\n    spotMatchList: () => req('/spot/match/list'),\n    spotMatchGet: id => req(`/spot/match/${id}`),\n    spotMatchJoin: id => req(`/spot/match/${id}/join`, {\n      method: 'POST'\n    }),\n    spotMatchDecline: id => req(`/spot/match/${id}/decline`, {\n      method: 'POST'\n    }),\n    spotMatchStart: id => req(`/spot/match/${id}/start`, {\n      method: 'POST'\n    }),\n    spotMatchCancel: id => req(`/spot/match/${id}/cancel`, {\n      method: 'POST'\n    }),\n    spotMatchCapture: (id, photo_base64) => req(`/spot/match/${id}/capture`, {\n      method: 'POST',\n      body: JSON.stringify({\n        photo_base64\n      })\n    }),\n    // ─── Direct Messages (with AI safety guard) ───────────────────\n    messagesRefine: text => req('/messages/refine', {\n      method: 'POST',\n      body: JSON.stringify({\n        text\n      })\n    }),\n    messagesCheckImage: image_base64 => req('/messages/check-image', {\n      method: 'POST',\n      body: JSON.stringify({\n        image_base64\n      })\n    }),\n    messagesSend: (to_user_id, refined_text, original_text, image_base64) => req('/messages/send', {\n      method: 'POST',\n      body: JSON.stringify({\n        to_user_id,\n        refined_text,\n        original_text,\n        image_base64\n      })\n    }),\n    messagesThreads: () => req('/messages/threads'),\n    messagesThread: friend_id => req(`/messages/thread/${friend_id}`),\n    messagesRead: friend_id => req('/messages/read', {\n      method: 'POST',\n      body: JSON.stringify({\n        friend_id\n      })\n    }),\n    messagesUnreadSummary: () => req('/messages/unread-summary'),\n    pushRegisterToken: (token, platform) => req('/push/register-token', {\n      method: 'POST',\n      body: JSON.stringify({\n        token,\n        platform\n      })\n    }),\n    // ─── Per-friend chat preferences (colors + mute + soft-block) ─────\n    chatPrefsBulk: () => req('/chat/preferences'),\n    chatPrefsGet: friendId => req(`/chat/preferences/${friendId}`),\n    chatPrefsUpsert: (friendId, patch) => req(`/chat/preferences/${friendId}`, {\n      method: 'POST',\n      body: JSON.stringify(patch)\n    }),\n    chatPrefsMute: (friendId, value) => req(`/chat/preferences/${friendId}/mute`, {\n      method: 'POST',\n      body: JSON.stringify({\n        value\n      })\n    }),\n    chatPrefsBlock: (friendId, value) => req(`/chat/preferences/${friendId}/block`, {\n      method: 'POST',\n      body: JSON.stringify({\n        value\n      })\n    }),\n    // ─── Duo Referral Discounts (Library+) ─────────────────────────\n    libraryDuoOfferSet: (appId, requiredPeople, discountedPrice, currency = 'USD') => req(`/library/pricing/${appId}/duo-discount`, {\n      method: 'POST',\n      body: JSON.stringify({\n        required_people: requiredPeople,\n        discounted_price: discountedPrice,\n        currency\n      })\n    }),\n    libraryDuoOfferClear: appId => req(`/library/pricing/${appId}/duo-discount`, {\n      method: 'DELETE'\n    }),\n    libraryDuoOfferGet: appId => req(`/library/duo-offer/${appId}`),\n    duoCreate: appId => req('/duo/create', {\n      method: 'POST',\n      body: JSON.stringify({\n        app_id: appId\n      })\n    }),\n    duoJoin: codeOrGroupId => req('/duo/join', {\n      method: 'POST',\n      body: JSON.stringify(codeOrGroupId)\n    }),\n    duoLeave: groupId => req(`/duo/${groupId}/leave`, {\n      method: 'POST',\n      body: '{}'\n    }),\n    duoMy: () => req('/duo/my'),\n    duoGet: groupId => req(`/duo/${groupId}`),\n    adminPurchaseHistory: () => req('/admin/purchase-history'),\n    // ─── v1.0.29 Admin Player Tools ────────────────────────────────\n    /** Per-player price overrides (Creator-set, applies only to that player). */\n    adminPriceOverridesList: userId => req(`/admin/players/${userId}/price-overrides`),\n    adminPriceOverrideUpsert: (userId, appId, overridePrice, currency = 'USD') => req(`/admin/players/${userId}/price-overrides/${appId}`, {\n      method: 'POST',\n      body: JSON.stringify({\n        override_price: overridePrice,\n        currency\n      })\n    }),\n    adminPriceOverrideClear: (userId, appId) => req(`/admin/players/${userId}/price-overrides/${appId}`, {\n      method: 'DELETE'\n    }),\n    /** Hard-delete a player account. Cascades to every collection. Body\n     *  must include {confirm:'DELETE'} as a guard against accidental taps. */\n    adminDeletePlayer: userId => req(`/admin/players/${userId}`, {\n      method: 'DELETE',\n      body: JSON.stringify({\n        confirm: 'DELETE'\n      })\n    }),\n    /** Inactive players list — bucket '2w' | '1m' | '6m'. */\n    adminInactivePlayers: bucket => req(`/admin/players/inactive?bucket=${bucket}`),\n    // ─── Buried Treasure mini-app (Phase 1 — daily solo hunt) ──────\n    btLocationGet: () => req('/bt/location'),\n    btLocationSet: (lat, lng, radius_m, label, tz_offset_minutes) => req('/bt/location', {\n      method: 'POST',\n      body: JSON.stringify({\n        lat,\n        lng,\n        radius_m,\n        label,\n        tz_offset_minutes\n      })\n    }),\n    btChestToday: () => req('/bt/chest/today'),\n    btChestFind: (lat, lng, photoBase64) => req('/bt/chest/find', {\n      method: 'POST',\n      body: JSON.stringify({\n        lat,\n        lng,\n        photo_base64: photoBase64\n      })\n    }),\n    btFindsHistory: () => req('/bt/finds'),\n    btSettingsGet: () => req('/bt/settings'),\n    btSettingsSet: daylight_only => req('/bt/settings', {\n      method: 'POST',\n      body: JSON.stringify({\n        daylight_only\n      })\n    }),\n    btZonesList: () => req('/bt/no-go-zones'),\n    btZoneCreate: (name, polygon) => req('/bt/no-go-zones', {\n      method: 'POST',\n      body: JSON.stringify({\n        name,\n        polygon\n      })\n    }),\n    btZoneDelete: zoneId => req(`/bt/no-go-zones/${zoneId}`, {\n      method: 'DELETE'\n    }),\n    btReport: (kind, message, extra) => req('/bt/report', {\n      method: 'POST',\n      body: JSON.stringify(Object.assign({\n        kind,\n        message\n      }, extra || {}))\n    }),\n    // Health Connect debug reporter — used by the Sleep / \"Connect Samsung\n    // Health\" flow to ship native crashes + error messages to the server\n    // so we can audit why the system permission dialog never appears.\n    reportHealthConnectError: payload => req('/debug/health-connect-error', {\n      method: 'POST',\n      body: JSON.stringify(payload)\n    }),\n    // ─── Admin reports (Creator only) ─────────────────────────────\n    adminReportsList: () => req('/admin/reports'),\n    adminReportView: id => req(`/admin/reports/${id}/view`, {\n      method: 'POST'\n    }),\n    adminReportDismiss: id => req(`/admin/reports/${id}/dismiss`, {\n      method: 'POST'\n    }),\n    // ─── Admin / Creator catalog ──────────────────────────────────────\n    libraryCatalog: () => req('/library/catalog'),\n    authMe: () => req('/auth/me'),\n    getProfile: () => req('/profile'),\n    updateProfile: name => req('/profile', {\n      method: 'PUT',\n      body: JSON.stringify({\n        name\n      })\n    }),\n    updateWakeTime: wake_time => req('/profile', {\n      method: 'PUT',\n      body: JSON.stringify({\n        wake_time\n      })\n    }),\n    completeMorningSetup: wake_time => req('/profile', {\n      method: 'PUT',\n      body: JSON.stringify({\n        wake_time,\n        morning_setup_done: true\n      })\n    }),\n    // New day-anchor system: set BOTH timezone + day_start_time in a single write.\n    setDayAnchor: (timezone, day_start_time) => req('/profile', {\n      method: 'PUT',\n      body: JSON.stringify({\n        timezone,\n        day_start_time,\n        onboarding_tz_done: true\n      })\n    }),\n    answerPastChallenge: (completionId, body) => req(`/challenge/past/${completionId}/answer`, {\n      method: 'POST',\n      body: JSON.stringify(body)\n    }),\n    resetProfile: () => req('/profile/reset', {\n      method: 'POST'\n    }),\n    completeOnboarding: payload => req('/profile/onboarding', {\n      method: 'PUT',\n      body: JSON.stringify(payload)\n    }),\n    setAvatar: avatar_base64 => req('/profile/avatar', {\n      method: 'POST',\n      body: JSON.stringify({\n        avatar_base64\n      })\n    }),\n    seed: () => req('/seed', {\n      method: 'POST'\n    }),\n    listTasks: date => req(`/tasks${date ? `?date=${date}` : ''}`),\n    createTask: body => req('/tasks', {\n      method: 'POST',\n      body: JSON.stringify(Object.assign({\n        recurring: true,\n        reminder_enabled: true\n      }, body))\n    }),\n    updateTask: (id, body) => req(`/tasks/${id}`, {\n      method: 'PUT',\n      body: JSON.stringify(body)\n    }),\n    deleteTask: id => req(`/tasks/${id}`, {\n      method: 'DELETE'\n    }),\n    completeTask: (id, date) => req(`/tasks/${id}/complete`, {\n      method: 'POST',\n      body: JSON.stringify({\n        date\n      })\n    }),\n    uncompleteTask: (id, date) => req(`/tasks/${id}/uncomplete`, {\n      method: 'POST',\n      body: JSON.stringify({\n        date\n      })\n    }),\n    listGoals: () => req('/goals'),\n    goalsXpCaps: () => req('/goals/xp-caps'),\n    createGoal: body => req('/goals', {\n      method: 'POST',\n      body: JSON.stringify(body)\n    }),\n    updateGoalProgress: (id, current_value) => req(`/goals/${id}/progress`, {\n      method: 'POST',\n      body: JSON.stringify({\n        current_value\n      })\n    }),\n    deleteGoal: id => req(`/goals/${id}`, {\n      method: 'DELETE'\n    }),\n    achievements: () => req('/achievements'),\n    statsDaily: date => req(`/stats/daily${date ? `?date=${date}` : ''}`),\n    statsWeekly: () => req('/stats/weekly'),\n    statsMonthly: () => req('/stats/monthly'),\n    statsByArea: () => req('/stats/by-area'),\n    // ──────── Library+ Mini-App Ratings ────────\n    // Returns aggregate stats for all 4 featured mini-apps + the\n    // caller's own rating per app (null if never rated).\n    libraryRatings: () => req('/library/ratings'),\n    // Upserts the caller's rating (1–5) for a single mini-app and\n    // returns the freshly recomputed aggregate so the UI can update\n    // without a full refetch.\n    rateMiniApp: (app_id, stars) => req('/library/ratings', {\n      method: 'POST',\n      body: JSON.stringify({\n        app_id,\n        stars\n      })\n    }),\n    // ──────── Library+ Mini-App Pricing & Purchases ────────\n    // Returns price/currency/discount info for all 4 mini-apps + a\n    // per-user `purchased` flag for each. Free apps (price=0) ALWAYS\n    // surface as `is_free:true`; the app card renders a green FREE pill\n    // for them and a price tag (with optional strikethrough) otherwise.\n    libraryPricing: () => req('/library/pricing'),\n    // Real-money purchases via Stripe Checkout. The backend looks up\n    // server-side pricing (so the client can never tamper with the\n    // amount) and returns a hosted Stripe Checkout URL the app opens\n    // in the system browser. Webhook flips `purchased=true` upon paid.\n    paymentsCreateCheckout: app_id => req('/payments/create-checkout', {\n      method: 'POST',\n      body: JSON.stringify({\n        app_id\n      })\n    }),\n    // Native PaymentSheet flow (mobile only) — returns the secrets\n    // PaymentSheet's initPaymentSheet() needs to render an in-app\n    // payment form (card field is a Stripe-controlled native component\n    // so we never see the raw PAN — PCI-DSS compliant).\n    paymentsCreatePaymentIntent: (app_id, kind = 'library', duo_group_id) => req('/payments/create-payment-intent', {\n      method: 'POST',\n      body: JSON.stringify({\n        app_id,\n        kind,\n        duo_group_id: duo_group_id || undefined\n      })\n    }),\n    // Polled after returning from Stripe — finalises OWNED state if the\n    // webhook hasn't arrived yet (e.g. whsec not configured locally).\n    paymentsVerifySession: session_id => req(`/payments/session/${encodeURIComponent(session_id)}/verify`),\n    // Creator-only: set price + currency + external purchase URL on a\n    // mini-app. price=0 means free.\n    libraryPricingSet: (app_id, payload) => req(`/library/pricing/${app_id}`, {\n      method: 'POST',\n      body: JSON.stringify(payload)\n    }),\n    // Creator-only: add or clear a time-limited discount on a mini-app.\n    // percent=0 clears any active discount.\n    libraryPricingDiscount: (app_id, payload) => req(`/library/pricing/${app_id}/discount`, {\n      method: 'POST',\n      body: JSON.stringify(payload)\n    }),\n    // Records a user's purchase of a priced mini-app after they've\n    // returned from the external checkout URL. Idempotent.\n    libraryPurchase: app_id => req(`/library/purchase/${app_id}`, {\n      method: 'POST'\n    }),\n    // ──────── Boost Pricing & Purchases (Points+ Boosts) ────────\n    // Same shape as libraryPricing — re-uses the LibraryAppPricing type\n    // (app_id is the boost_id like 'triple_day').\n    boostsPricing: () => req('/boosts/pricing'),\n    boostsPricingSet: (boost_id, payload) => req(`/boosts/pricing/${boost_id}`, {\n      method: 'POST',\n      body: JSON.stringify(payload)\n    }),\n    boostsPricingDiscount: (boost_id, payload) => req(`/boosts/pricing/${boost_id}/discount`, {\n      method: 'POST',\n      body: JSON.stringify(payload)\n    }),\n    // Trust-based fallback after returning from external Stripe checkout.\n    boostsPurchase: boost_id => req('/boosts/purchase', {\n      method: 'POST',\n      body: JSON.stringify({\n        boost_id\n      })\n    }),\n    // ──────── Adaptive Work-Life Scheduler ────────\n    // Pattern of Day/Night/Off shifts overrides the static day_start_time\n    // when enabled. Backend recalculates the boundary every request via\n    // user_today_str → _effective_day_start_for. Manual overrides per\n    // date take precedence over the rotating pattern.\n    scheduleGet: () => req('/schedule'),\n    schedulePut: payload => req('/schedule', {\n      method: 'PUT',\n      body: JSON.stringify(payload)\n    }),\n    scheduleReset: () => req('/schedule/reset', {\n      method: 'POST'\n    }),\n    scheduleDayOverride: (date_iso, shift) => req(`/schedule/day/${date_iso}`, {\n      method: 'PUT',\n      body: JSON.stringify({\n        shift\n      })\n    }),\n    schedulePreview: (days = 14, from_iso) => req(`/schedule/preview?days=${days}${from_iso ? `&from_=${from_iso}` : ''}`),\n    // ──────── In-app feedback + Level-up review prompts ────────  // POST /feedback — store the user's rating + free-text. Used both\n    // by the level-up modal AND th