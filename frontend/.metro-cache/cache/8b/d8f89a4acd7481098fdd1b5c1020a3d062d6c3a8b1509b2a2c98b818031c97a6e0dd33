le: name => req('/profile', {\n      method: 'PUT',\n      body: JSON.stringify({\n        name\n      })\n    }),\n    updateWakeTime: wake_time => req('/profile', {\n      method: 'PUT',\n      body: JSON.stringify({\n        wake_time\n      })\n    }),\n    completeMorningSetup: wake_time => req('/profile', {\n      method: 'PUT',\n      body: JSON.stringify({\n        wake_time,\n        morning_setup_done: true\n      })\n    }),\n    // New day-anchor system: set BOTH timezone + day_start_time in a single write.\n    setDayAnchor: (timezone, day_start_time) => req('/profile', {\n      method: 'PUT',\n      body: JSON.stringify({\n        timezone,\n        day_start_time,\n        onboarding_tz_done: true\n      })\n    }),\n    answerPastChallenge: (completionId, body) => req(`/challenge/past/${completionId}/answer`, {\n      method: 'POST',\n      body: JSON.stringify(body)\n    }),\n    resetProfile: () => req('/profile/reset', {\n      method: 'POST'\n    }),\n    completeOnboarding: payload => req('/profile/onboarding', {\n      method: 'PUT',\n      body: JSON.stringify(payload)\n    }),\n    setAvatar: avatar_base64 => req('/profile/avatar', {\n      method: 'POST',\n      body: JSON.stringify({\n        avatar_base64\n      })\n    }),\n    seed: () => req('/seed', {\n      method: 'POST'\n    }),\n    listTasks: date => req(`/tasks${date ? `?date=${date}` : ''}`),\n    createTask: body => req('/tasks', {\n      method: 'POST',\n      body: JSON.stringify({\n        recurring: true,\n        reminder_enabled: true,\n        ...body\n      })\n    }),\n    updateTask: (id, body) => req(`/tasks/${id}`, {\n      method: 'PUT',\n      body: JSON.stringify(body)\n    }),\n    deleteTask: id => req(`/tasks/${id}`, {\n      method: 'DELETE'\n    }),\n    completeTask: (id, date) => req(`/tasks/${id}/complete`, {\n      method: 'POST',\n      body: JSON.stringify({\n        date\n      })\n    }),\n    uncompleteTask: (id, date) => req(`/tasks/${id}/uncomplete`, {\n      method: 'POST',\n      body: JSON.stringify({\n        date\n      })\n    }),\n    listGoals: () => req('/goals'),\n    goalsXpCaps: () => req('/goals/xp-caps'),\n    createGoal: body => req('/goals', {\n      method: 'POST',\n      body: JSON.stringify(body)\n    }),\n    updateGoalProgress: (id, current_value) => req(`/goals/${id}/progress`, {\n      method: 'POST',\n      body: JSON.stringify({\n        current_value\n      })\n    }),\n    deleteGoal: id => req(`/goals/${id}`, {\n      method: 'DELETE'\n    }),\n    achievements: () => req('/achievements'),\n    statsDaily: date => req(`/stats/daily${date ? `?date=${date}` : ''}`),\n    statsWeekly: () => req('/stats/weekly'),\n    statsMonthly: () => req('/stats/monthly'),\n    statsByArea: () => req('/stats/by-area'),\n    // ──────── Library+ Mini-App Ratings ────────\n    // Returns aggregate stats for all 4 featured mini-apps + the\n    // caller's own rating per app (null if never rated).\n    libraryRatings: () => req('/library/ratings'),\n    // Upserts the caller's rating (1–5) for a single mini-app and\n    // returns the freshly recomputed aggregate so the UI can update\n    // without a full refetch.\n    rateMiniApp: (app_id, stars) => req('/library/ratings', {\n      method: 'POST',\n      body: JSON.stringify({\n        app_id,\n        stars\n      })\n    }),\n    // ──────── Library+ Mini-App Pricing & Purchases ────────\n    // Returns price/currency/discount info for all 4 mini-apps + a\n    // per-user `purchased` flag for each. Free apps (price=0) ALWAYS\n    // surface as `is_free:true`; the app card renders a green FREE pill\n    // for them and a price tag (with optional strikethrough) otherwise.\n    libraryPricing: () => req('/library/pricing'),\n    // Real-money purchases via Stripe Checkout. The backend looks up\n    // server-side pricing (so the client can never tamper with the\n    // amount) and returns a hosted Stripe Checkout URL the app opens\n    // in the system browser. Webhook flips `purchased=true` upon paid.\n    paymentsCreateCheckout: app_id => req('/payments/create-checkout', {\n      method: 'POST',\n      body: JSON.stringify({\n        app_id\n      })\n    }),\n    // Native PaymentSheet flow (mobile only) — returns the secrets\n    // PaymentSheet's initPaymentSheet() needs to render an in-app\n    // payment form (card field is a Stripe-controlled native component\n    // so we never see the raw PAN — PCI-DSS compliant).\n    paymentsCreatePaymentIntent: (app_id, kind = 'library', duo_group_id) => req('/payments/create-payment-intent', {\n      method: 'POST',\n      body: JSON.stringify({\n        app_id,\n        kind,\n        duo_group_id: duo_group_id || undefined\n      })\n    }),\n    // Polled after returning from Stripe — finalises OWNED state if the\n    // webhook hasn't arrived yet (e.g. whsec not configured locally).\n    paymentsVerifySession: session_id => req(`/payments/session/${encodeURIComponent(session_id)}/verify`),\n    // Creator-only: set price + currency + external purchase URL on a\n    // mini-app. price=0 means free.\n    libraryPricingSet: (app_id, payload) => req(`/library/pricing/${app_id}`, {\n      method: 'POST',\n      body: JSON.stringify(payload)\n    }),\n    // Creator-only: add or clear a time-limited discount on a mini-app.\n    // percent=0 clears any active discount.\n    libraryPricingDiscount: (app_id, payload) => req(`/library/pricing/${app_id}/discount`, {\n      method: 'POST',\n      body: JSON.stringify(payload)\n    }),\n    // Records a user's purchase of a priced mini-app after they've\n    // returned from the external checkout URL. Idempotent.\n    libraryPurchase: app_id => req(`/library/purchase/${app_id}`, {\n      method: 'POST'\n    }),\n    // ──────── Boost Pricing & Purchases (Points+ Boosts) ────────\n    // Same shape as libraryPricing — re-uses the LibraryAppPricing type\n    // (app_id is the boost_id like 'triple_day').\n    boostsPricing: () => req('/boosts/pricing'),\n    boostsPricingSet: (boost_id, payload) => req(`/boosts/pricing/${boost_id}`, {\n      method: 'POST',\n      body: JSON.stringify(payload)\n    }),\n    boostsPricingDiscount: (boost_id, payload) => req(`/boosts/pricing/${boost_id}/discount`, {\n      method: 'POST',\n      body: JSON.stringify(payload)\n    }),\n    // Trust-based fallback after returning from external Stripe checkout.\n    boostsPurchase: boost_id => req('/boosts/purchase', {\n      method: 'POST',\n      body: JSON.stringify({\n        boost_id\n      })\n    }),\n    // ──────── Adaptive Work-Life Scheduler ────────\n    // Pattern of Day/Night/Off shifts overrides the static day_start_time\n    // when enabled. Backend recalculates the boundary every request via\n    // user_today_str → _effective_day_start_for. Manual overrides per\n    // date take precedence over the rotating pattern.\n    scheduleGet: () => req('/schedule'),\n    schedulePut: payload => req('/schedule', {\n      method: 'PUT',\n      body: JSON.stringify(payload)\n    }),\n    scheduleReset: () => req('/schedule/reset', {\n      method: 'POST'\n    }),\n    scheduleDayOverride: (date_iso, shift) => req(`/schedule/day/${date_iso}`, {\n      method: 'PUT',\n      body: JSON.stringify({\n        shift\n      })\n    }),\n    schedulePreview: (days = 14, from_iso) => req(`/schedule/preview?days=${days}${from_iso ? `&from_=${from_iso}` : ''}`),\n    // ──────── In-app feedback + Level-up review prompts ────────  // POST /feedback — store the user's rating + free-text. Used both\n    // by the level-up modal AND the standalone Settings → Feedback\n    // screen. Once submitted, the level-up prompts skip the inline\n    // feedback section on subsequent levels.\n    submitFeedback: payload => req('/feedback', {\n      method: 'POST',\n      body: JSON.stringify(payload)\n    }),\n    // GET /feedback/me — has this user submitted feedback yet? Used\n    // by useLevelUpDetector to decide whether to